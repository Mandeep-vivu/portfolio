# Gemini stays server-only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=

# Public application configuration.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/mandeepsingh7official/30min

# Admin authentication. AUTH_SECRET must be at least 32 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=
AUTH_SECRET=

# Persistent production content# Database Variables (e.g. Supabase, Vercel Postgres)
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub Sync
GITHUB_USERNAME=Mandeep-vivu
GITHUB_TOKEN= # Optional, prevents rate limiting

# Persistent production content storage (Upstash Redis REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob token for PDF resume uploads.
BLOB_READ_WRITE_TOKEN=

# AI Fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=